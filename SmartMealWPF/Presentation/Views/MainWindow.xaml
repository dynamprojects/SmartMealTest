<Window x:Class="SmartMealWPF.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartMealWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStyle="None" Background="#FFD4D175" MouseLeftButtonDown="Border_MouseLeftButtonDown">
    <Border BorderBrush="#1C1C1C" BorderThickness="4" CornerRadius="28" Background="White" Margin="15" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="43*"/>
                <RowDefinition Height="353*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="75" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="EnvDataGrid"
                          Grid.Column="0"
                          Margin="20,10,22,20"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          ItemsSource="{Binding Variables}"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="#F9F9F9" Grid.Row="1" Grid.ColumnSpan="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="" 
                                            Binding="{Binding Number}" 
                                            Width="60" 
                                            IsReadOnly="True" 
                                            FontWeight="Bold"/>
                    <DataGridTextColumn Header="Поле" 
                                            Binding="{Binding Name}" 
                                            Width="Auto" 
                                            MinWidth="220" 
                                            IsReadOnly="True"/>

                    <DataGridTextColumn Header="Значение" 
                                            Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                            Width="*" 
                                            MinWidth="320">
                        <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                            <EventSetter Event="PreviewTextInput" Handler="OnlyText_PreviewTextInput"/>
                            <EventSetter Event="DataObject.Pasting" Handler="OnPaste"/>
                        </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Комментарий" 
                                            Binding="{Binding Comment}" 
                                            Width="Auto" 
                                            MinWidth="180" 
                                            IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Column="1"
                           Text="Тестовое WPF-приложение для SmartMeaService"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#1C1C1C"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5" Grid.Row="1" Height="23">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-90"/>
                </TextBlock.RenderTransform>
            </TextBlock>
            <Button
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="10,0,0,0"
                        Width="25" Height="23"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="11"
                        Foreground="#1C1C1C"
                        Content="_"
                        Command="{Binding MinimizeCommand}" 
                        Click="MinButton_Click" Grid.Row="0" Grid.Column="1"/>
            <Button
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="40,0,0,0"
                        Width="25" Height="23"
                        Background="Transparent"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Foreground="#1C1C1C"
                        Content="X"
                        Command="{Binding CloseCommand}"
                        Click="CloseButton_Click" Grid.Row="0" Grid.Column="1" FontSize="16"/>
        </Grid>
    </Border>
</Window>
