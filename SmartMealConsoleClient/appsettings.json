{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=smartmeal_db;Username=postgres;Password=postgres123"
  },
  "SmartMealOptions": {
    "Protocol": "grpc",
    "AuthenticationType":"Basic",
    "BaseUrl": "http://localhost",
    "Username": "test",
    "Password": "test",
    "HttpPort": 8080,
    "GrpcPort": 50051
  },
  "Serilog": {
    "MinimumLevel":  {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Error",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "test-sms-console-app-.log",
          "restrictedToMinimumLevel": "Debug",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level}] {Message}{NewLine}{Exception}"
        }
      }
    ]
  }
}